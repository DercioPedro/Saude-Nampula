    { "source": "/emer", "destination": "/emer.html" },
    { "source": "/sobre", "destination": "/sobre.html" },
    { "source": "/info", "destination": "/info.html" },
    { "source": "/admin-login", "destination": "/admin-login.html" },
    { "source": "/admin-panel", "destination": "/admin-panel.html" },
    { "source": "/admin-produtos", "destination": "/admin-produtos.html" },
    { "source": "/login-farmacia", "destination": "/login-farmacia.html" },
    { "source": "/medicamentos", "destination": "/medicamentos.html" },
    { "source": "/detalhes-farmacia", "destination": "/detalhes-farmacia.html" },
